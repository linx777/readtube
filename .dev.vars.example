# Optional for quick mode.
# Required if you want "详细版" to call Gemini and return the AI summary/speakers panel.
GEMINI_API_KEY=your_google_ai_studio_key

# Optional legacy override for the first-stage insights call.
GEMINI_MODEL=gemini-3.1-pro-preview

# Optional explicit overrides.
GEMINI_INSIGHTS_MODEL=gemini-3.1-pro-preview
GEMINI_DIALOGUE_MODEL=gemini-3.1-flash-lite-preview
